# Keep the Docker build context small & reproducible.
# Virtualenvs / IDE / caches
.venv/
venv/
.idea/
.claude/
__pycache__/
**/__pycache__/
*.pyc
*.pyo

# Local runtime artifacts
logs/
*.log

# Secrets & local env
.env

# VCS
.git/
.gitignore

# Docs / handoffs (not needed in the image)
HANDOFF*.md
AGENTS.md
CLAUDE.md

# OS cruft
.DS_Store
Thumbs.db

